PORT=5000
# Local MongoDB or MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/carrental
JWT_SECRET=please-change-me
JWT_EXPIRES=7d
CLIENT_ORIGIN=http://localhost:3000

# Super-admin (created on first start if none exists)
SUPERADMIN_EMAIL=superadmin@app.com
SUPERADMIN_PASSWORD=super123

# Public URL of the FRONTEND — used to build password-reset links in emails
APP_URL=http://localhost:3000

# Email (SMTP) — required for "Forgot password" emails to actually send.
# Leave blank/commented to keep dev mode (reset link is printed to the server console).
# --- Gmail example (use a Google "App Password", NOT your normal password) ---
#   1. Enable 2-Step Verification on the Google account
#   2. Google Account → Security → App passwords → generate one for "Mail"
#   3. Put the 16-char app password in SMTP_PASS below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=SelfDrive Car Rentals <youraddress@gmail.com>

# Push notifications (Firebase Cloud Messaging) — required for the mobile app to
# receive overdue-return / expiring-document alerts. Leave blank to keep dev mode
# (pushes are logged, not sent). Value = path to the service-account JSON file
# (Firebase Console → Project Settings → Service accounts → Generate new private key),
# or the raw JSON string itself.
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
