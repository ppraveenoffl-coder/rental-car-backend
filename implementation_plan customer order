## 2. Proposed Database Changes

### [NEW] [customerStaff.schema.ts](file:///c:/ASM%20Project/Git/ASM-Sales-backend/ASM-SalesBackend/src/schemas/customerStaff.schema.ts)
Stores individual staff details linked to a parent `Customer`:

```typescript
import { Schema, Prop, SchemaFactory } from '@nestjs/mongoose';
import mongoose, { Document, ObjectId } from 'mongoose';

@Schema({
    timestamps: true,
    versionKey: false
})
export class CustomerStaff extends Document {
    _id: ObjectId;

    @Prop({ type: mongoose.Schema.Types.ObjectId, ref: 'Customer', required: true })
    customer_id: ObjectId; // Links to "Raja"

    @Prop({ type: String, required: true })
    name: string; // e.g. "Raja Manager"

    @Prop({ type: String, required: true, unique: true })
    mobile_no: string;

    @Prop({ type: Number, default: 1 }) // 0 - Inactive, 1 - Active
    status: number;

    @Prop({ type: String })
    device_id: string;

    @Prop({ type: String })
    token: string;

    @Prop({ type: [String], default: ['view_orders', 'create_orders'] })
    permissions: string[];
}

export const CustomerStaffSchema = SchemaFactory.createForClass(CustomerStaff);
CustomerStaffSchema.index({ mobile_no: 1 });
CustomerStaffSchema.index({ customer_id: 1 });
```

